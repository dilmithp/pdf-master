# Database (per-service connections)
DB_URL=jdbc:postgresql://localhost:5432/pdfmaster
DB_USERNAME=pdfmaster
DB_PASSWORD=pdfmaster

# pdf-ai-service uses the pgvector-enabled cluster on 5433
DB_URL_PGVECTOR=jdbc:postgresql://localhost:5433/pdfmaster

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest

# S3 (MinIO locally)
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=pdfmaster-uploads
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin

# Auth (provider-agnostic OAuth2 RS) — defaults point at auth-service's own AS
AUTH_ISSUER_URI=http://localhost:8081
AUTH_JWKS_URI=http://localhost:8081/oauth2/jwks

# Stripe (use Stripe test mode keys)
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Postmark (use Mailhog locally — point SMTP at localhost:1025; for production use real Postmark)
POSTMARK_SERVER_TOKEN=mailhog-local

# OpenAI/Anthropic (only needed when AI features wired)
ANTHROPIC_API_KEY=sk-ant-replace-me
